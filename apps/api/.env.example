# Database
DATABASE_URL=postgresql://user:password@localhost:5432/giftlandiya

# Redis
REDIS_URL=redis://localhost:6379

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=your_meilisearch_master_key

# JWT
JWT_SECRET=your_jwt_secret_minimum_32_characters_long
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_minimum_32_characters_long
JWT_REFRESH_EXPIRES_IN=30d

# AI
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-...

# Payme
PAYME_MERCHANT_ID=your_merchant_id
PAYME_SECRET=your_payme_secret

# Click
CLICK_SERVICE_ID=your_service_id
CLICK_MERCHANT_USER_ID=your_merchant_user_id
CLICK_SECRET=your_click_secret

# Eskiz (SMS provider)
ESKIZ_EMAIL=your@email.com
ESKIZ_PASSWORD=your_eskiz_password

# Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABC-your_bot_token
TELEGRAM_ADMIN_CHAT_ID=-100your_chat_id

# Cloudflare R2 Storage
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY=your_access_key_id
R2_SECRET_KEY=your_secret_access_key
R2_BUCKET=giftlandiya
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Frontend URLs (used for CORS)
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
SELLER_URL=http://localhost:3002

# App
NODE_ENV=development
PORT=4000
